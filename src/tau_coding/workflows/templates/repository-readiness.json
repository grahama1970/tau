{
  "schema": "tau.generic_dag_spec.v1",
  "run_id": "${RUN_ID}",
  "run_dir": "${RUN_DIR}",
  "goal": "${GOAL_OBJECT}",
  "goal_hash": "${GOAL_HASH}",
  "workflow": "${WORKFLOW_METADATA}",
  "max_concurrency": 1,
  "nodes": [
    {
      "node_id": "inspect-repository",
      "role": "Inspect repository",
      "command": ["${PYTHON}", "-m", "tau_coding.workflows.nodes.repository_readiness", "inspect", "--request", "${REQUEST_PATH}", "--output", "${INSPECTION_PATH}", "--receipt", "${INSPECTION_RECEIPT}", "--step-delay-seconds", "${STEP_DELAY_SECONDS}"],
      "depends_on": [],
      "accepted_context_from": [],
      "receipt_path": "${INSPECTION_RECEIPT}",
      "timeout_seconds": 30,
      "max_attempts": 1
    },
    {
      "node_id": "validate-readiness",
      "role": "Validate readiness policy",
      "command": ["${PYTHON}", "-m", "tau_coding.workflows.nodes.repository_readiness", "validate", "--request", "${REQUEST_PATH}", "--output", "${VALIDATION_PATH}", "--receipt", "${VALIDATION_RECEIPT}", "--step-delay-seconds", "${STEP_DELAY_SECONDS}"],
      "depends_on": ["inspect-repository"],
      "accepted_context_from": ["inspect-repository"],
      "receipt_path": "${VALIDATION_RECEIPT}",
      "timeout_seconds": 30,
      "max_attempts": 1
    },
    {
      "node_id": "publish-readiness",
      "role": "Publish readiness result",
      "command": ["${PYTHON}", "-m", "tau_coding.workflows.nodes.repository_readiness", "publish", "--request", "${REQUEST_PATH}", "--json-output", "${RESULT_JSON}", "--markdown-output", "${RESULT_MARKDOWN}", "--receipt", "${PUBLISH_RECEIPT}", "--step-delay-seconds", "${STEP_DELAY_SECONDS}"],
      "depends_on": ["inspect-repository", "validate-readiness"],
      "accepted_context_from": ["inspect-repository", "validate-readiness"],
      "receipt_path": "${PUBLISH_RECEIPT}",
      "timeout_seconds": 30,
      "max_attempts": 1
    }
  ]
}
