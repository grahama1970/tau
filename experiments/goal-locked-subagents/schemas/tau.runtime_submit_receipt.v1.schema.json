{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "tau.runtime_submit_receipt.v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "endpoint_lease_sha256", "work_order_sha256", "composer_state_before", "text_delivery_count", "submit_attempt_count", "composer_state_after", "delivery_status", "backend_acknowledgement", "provider_execution_status", "errors"],
  "properties": {
    "schema": {"const": "tau.runtime_submit_receipt.v1"}, "endpoint_lease_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "work_order_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "composer_state_before": {"type": "string", "minLength": 1}, "text_delivery_count": {"type": "integer", "minimum": 0}, "submit_attempt_count": {"type": "integer", "minimum": 0}, "composer_state_after": {"type": "string", "minLength": 1},
    "delivery_status": {"type": "string", "minLength": 1}, "backend_acknowledgement": {"type": "object"}, "provider_execution_status": {"type": "string", "minLength": 1}, "errors": {"type": "array", "items": {"type": "string"}}
  }
}
