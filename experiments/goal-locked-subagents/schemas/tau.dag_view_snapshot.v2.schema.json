{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tau DAG view snapshot v2",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "journal_sequence",
    "snapshot_sha256",
    "view",
    "run_status",
    "projection_state",
    "nodes",
    "edges",
    "terminals",
    "routes",
    "joins",
    "corrections",
    "attention_items",
    "recent_events",
    "proof_scope",
    "redaction"
  ],
  "properties": {
    "schema": {"const": "tau.dag_view_snapshot.v2"},
    "run_id": {"type": "string", "minLength": 1},
    "journal_sequence": {"type": "integer", "minimum": 1},
    "snapshot_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "view": {
      "type": "object",
      "required": ["mode", "sequence", "sequence_created_at"],
      "properties": {
        "mode": {"enum": ["LIVE", "HISTORICAL"]},
        "sequence": {"type": "integer", "minimum": 1},
        "sequence_created_at": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "run_status": {"type": "string"},
    "run_verdict": {"type": ["string", "null"]},
    "projection_state": {"type": "string"},
    "nodes": {"type": "array"},
    "edges": {"type": "array"},
    "terminals": {"type": "array"},
    "routes": {"type": "array"},
    "joins": {"type": "array"},
    "corrections": {"type": "array"},
    "attention_items": {"type": "array"},
    "recent_events": {"type": "array"},
    "proof_scope": {"type": "object"},
    "redaction": {"type": "object"}
  },
  "additionalProperties": false
}
