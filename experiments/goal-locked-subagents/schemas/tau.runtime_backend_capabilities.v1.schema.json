{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tau.runtime_backend_capabilities.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "backend", "version", "interactive", "one_shot", "native_events", "native_agent_state", "foreground_process_state", "structured_composer_state", "stable_endpoint_id", "human_attach", "supports_working_directory", "supports_owned_inventory", "supports_terminate", "observation_confidence_levels", "supported_session_scopes", "unsupported_requirements"],
  "properties": {
    "schema": {"const": "tau.runtime_backend_capabilities.v1"},
    "backend": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "interactive": {"type": "boolean"}, "one_shot": {"type": "boolean"},
    "native_events": {"type": "boolean"}, "native_agent_state": {"type": "boolean"},
    "foreground_process_state": {"type": "boolean"}, "structured_composer_state": {"type": "boolean"},
    "stable_endpoint_id": {"type": "boolean"}, "human_attach": {"type": "boolean"},
    "supports_working_directory": {"type": "boolean"}, "supports_owned_inventory": {"type": "boolean"},
    "supports_terminate": {"type": "boolean"},
    "observation_confidence_levels": {"type": "array", "items": {"enum": ["NATIVE", "PROCESS", "HEURISTIC", "UNKNOWN"]}, "uniqueItems": true},
    "supported_session_scopes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "unsupported_requirements": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
