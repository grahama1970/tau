{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tau.agent_handoff.v1",
  "title": "Tau Agent Handoff",
  "type": "object",
  "required": [
    "schema",
    "github",
    "goal",
    "previous_subagent",
    "context",
    "result",
    "rationale",
    "next_agent",
    "required_evidence",
    "stop_condition"
  ],
  "properties": {
    "schema": {
      "const": "tau.agent_handoff.v1"
    },
    "github": {
      "$ref": "tau.agent_common.v1.schema.json#/$defs/githubTarget"
    },
    "goal": {
      "$ref": "tau.agent_common.v1.schema.json#/$defs/goalRef"
    },
    "previous_subagent": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "$ref": "tau.agent_common.v1.schema.json#/$defs/context"
    },
    "result": {
      "type": "object",
      "required": ["status", "summary", "evidence"],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "next_agent": {
      "$ref": "tau.agent_common.v1.schema.json#/$defs/nextAgent"
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stop_condition": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
