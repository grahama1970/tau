{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tau.dag_contract.v1",
  "title": "Tau Project-Agent DAG Contract",
  "type": "object",
  "additionalProperties": true,
  "$defs": {
    "dagIdentifier": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,63}$"
    },
    "routeScalar": {
      "oneOf": [
        {"type": "string", "maxLength": 4096},
        {"type": "boolean"},
        {"type": "number"},
        {"type": "null"}
      ]
    },
    "routeScalarList": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {"type": "string", "maxLength": 4096}
        },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {"type": "boolean"}
        },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {"type": "number"}
        },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {"type": "null"}
        }
      ]
    },
    "routeField": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]{0,63}$",
      "not": {
        "enum": [
          "artifacts",
          "commands_run",
          "errors",
          "evidence",
          "policy_exceptions",
          "proof_scope",
          "summary"
        ]
      }
    },
    "routeLeafCondition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "op", "field", "value"],
          "properties": {
            "schema": {"const": "tau.route_condition.v1"},
            "op": {"enum": ["eq", "neq"]},
            "field": {"$ref": "#/$defs/routeField"},
            "value": {
              "oneOf": [
                {"$ref": "#/$defs/routeScalar"},
                {"$ref": "#/$defs/routeScalarList"}
              ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "op", "field", "value"],
          "properties": {
            "schema": {"const": "tau.route_condition.v1"},
            "op": {"enum": ["in", "not_in"]},
            "field": {"$ref": "#/$defs/routeField"},
            "value": {"$ref": "#/$defs/routeScalarList"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "op", "field"],
          "properties": {
            "schema": {"const": "tau.route_condition.v1"},
            "op": {"const": "exists"},
            "field": {"$ref": "#/$defs/routeField"}
          }
        }
      ]
    },
    "routeConditionLevel0": {
      "$ref": "#/$defs/routeLeafCondition"
    },
    "routeCompoundLevel1": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "op", "conditions"],
          "properties": {
            "schema": {"const": "tau.route_condition.v1"},
            "op": {"enum": ["all", "any"]},
            "conditions": {
              "type": "array",
              "minItems": 1,
              "maxItems": 64,
              "items": {"$ref": "#/$defs/routeConditionLevel0"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "op", "condition"],
          "properties": {
            "schema": {"const": "tau.route_condition.v1"},
            "op": {"const": "not"},
            "condition": {"$ref": "#/$defs/routeConditionLevel0"}
          }
        }
      ]
    },
    "routeConditionLevel1": {
      "oneOf": [
        {"$ref": "#/$defs/routeConditionLevel0"},
        {"$ref": "#/$defs/routeCompoundLevel1"}
      ]
    },
    "routeCompoundLevel2": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "op", "conditions"],
          "properties": {
            "schema": {"const": "tau.route_condition.v1"},
            "op": {"enum": ["all", "any"]},
            "conditions": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/routeConditionLevel1"}}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "op", "condition"],
          "properties": {
            "schema": {"const": "tau.route_condition.v1"},
            "op": {"const": "not"},
            "condition": {"$ref": "#/$defs/routeConditionLevel1"}
          }
        }
      ]
    },
    "routeConditionLevel2": {"oneOf": [{"$ref": "#/$defs/routeConditionLevel1"}, {"$ref": "#/$defs/routeCompoundLevel2"}]},
    "routeCompoundLevel3": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "conditions"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"enum": ["all", "any"]}, "conditions": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/routeConditionLevel2"}}}},
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "condition"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"const": "not"}, "condition": {"$ref": "#/$defs/routeConditionLevel2"}}}
      ]
    },
    "routeConditionLevel3": {"oneOf": [{"$ref": "#/$defs/routeConditionLevel2"}, {"$ref": "#/$defs/routeCompoundLevel3"}]},
    "routeCompoundLevel4": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "conditions"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"enum": ["all", "any"]}, "conditions": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/routeConditionLevel3"}}}},
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "condition"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"const": "not"}, "condition": {"$ref": "#/$defs/routeConditionLevel3"}}}
      ]
    },
    "routeConditionLevel4": {"oneOf": [{"$ref": "#/$defs/routeConditionLevel3"}, {"$ref": "#/$defs/routeCompoundLevel4"}]},
    "routeCompoundLevel5": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "conditions"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"enum": ["all", "any"]}, "conditions": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/routeConditionLevel4"}}}},
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "condition"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"const": "not"}, "condition": {"$ref": "#/$defs/routeConditionLevel4"}}}
      ]
    },
    "routeConditionLevel5": {"oneOf": [{"$ref": "#/$defs/routeConditionLevel4"}, {"$ref": "#/$defs/routeCompoundLevel5"}]},
    "routeCompoundLevel6": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "conditions"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"enum": ["all", "any"]}, "conditions": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/routeConditionLevel5"}}}},
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "condition"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"const": "not"}, "condition": {"$ref": "#/$defs/routeConditionLevel5"}}}
      ]
    },
    "routeConditionLevel6": {"oneOf": [{"$ref": "#/$defs/routeConditionLevel5"}, {"$ref": "#/$defs/routeCompoundLevel6"}]},
    "routeCompoundLevel7": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "conditions"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"enum": ["all", "any"]}, "conditions": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"$ref": "#/$defs/routeConditionLevel6"}}}},
        {"type": "object", "additionalProperties": false, "required": ["schema", "op", "condition"], "properties": {"schema": {"const": "tau.route_condition.v1"}, "op": {"const": "not"}, "condition": {"$ref": "#/$defs/routeConditionLevel6"}}}
      ]
    },
    "routeConditionLevel7": {"oneOf": [{"$ref": "#/$defs/routeConditionLevel6"}, {"$ref": "#/$defs/routeCompoundLevel7"}]},
    "routeCondition": {
      "$ref": "#/$defs/routeConditionLevel7",
      "x-tau-max-depth": 8,
      "x-tau-runtime-max-condition-objects": 64,
      "$comment": "JSON Schema enforces depth and per-array limits. Tau's runtime normalizer enforces the 64-object total across the complete condition tree."
    },
    "joinPolicy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "policy", "timeout_seconds", "required_successes"],
          "properties": {
            "schema": {"const": "tau.dag_join_policy.v1"},
            "policy": {"enum": ["exact_success_count", "minimum_success_count"]},
            "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 86400},
            "required_successes": {"type": "integer", "minimum": 1}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "policy", "timeout_seconds", "quorum_fraction"],
          "properties": {
            "schema": {"const": "tau.dag_join_policy.v1"},
            "policy": {"const": "quorum"},
            "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 86400},
            "quorum_fraction": {
              "type": "object",
              "additionalProperties": false,
              "required": ["numerator", "denominator"],
              "properties": {
                "numerator": {"type": "integer", "minimum": 1, "maximum": 1000},
                "denominator": {"type": "integer", "minimum": 1, "maximum": 1000}
              },
              "$comment": "Tau runtime additionally requires numerator <= denominator and a reduced fraction; JSON Schema cannot express that cross-field gcd invariant."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema", "policy", "timeout_seconds"],
          "properties": {
            "schema": {"const": "tau.dag_join_policy.v1"},
            "policy": {
              "enum": [
                "all_success",
                "all_terminal",
                "any_success",
                "fail_fast",
                "collect_failures"
              ]
            },
            "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 86400}
          }
        }
      ]
    }
  },
  "required": [
    "schema",
    "dag_id",
    "goal",
    "target",
    "entry_node",
    "terminal_nodes",
    "limits",
    "nodes",
    "edges",
    "required_evidence",
    "fail_closed_on"
  ],
  "properties": {
    "schema": {
      "const": "tau.dag_contract.v1"
    },
    "dag_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "provider_sensitive": {
      "type": "boolean"
    },
    "requires_provider_route": {
      "type": "boolean"
    },
    "goal": {
      "type": "object",
      "additionalProperties": true,
      "required": ["goal_id", "goal_version", "goal_hash"],
      "properties": {
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "goal_version": {
          "type": ["integer", "string"]
        },
        "goal_hash": {
          "type": "string",
          "pattern": "^sha256:.+"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repo", "target"],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "entry_node": {
      "$ref": "#/$defs/dagIdentifier"
    },
    "terminal_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/dagIdentifier"
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": true,
      "required": ["max_total_attempts"],
      "properties": {
        "resume": {
          "type": "boolean"
        },
        "default_timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_total_attempts": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "agent", "executor"],
        "properties": {
          "id": {
            "$ref": "#/$defs/dagIdentifier"
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "executor": {
            "type": "string",
            "minLength": 1
          },
          "runtime_backend": {
            "type": "string",
            "minLength": 1
          },
          "max_attempts": {
            "type": "integer",
            "minimum": 1
          },
          "command_spec": {
            "type": "string",
            "minLength": 1
          },
          "route": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode"],
            "properties": {
              "mode": {
                "enum": ["exclusive", "first_match", "fanout", "all_matching"]
              }
            }
          },
          "join": {
            "$ref": "#/$defs/joinPolicy"
          },
          "required_evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reviewer": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "reviews_node": {
                "type": "string",
                "minLength": 1
              },
              "requires_goal_hash": {
                "type": "boolean"
              }
            }
          },
          "model_policy": {
            "type": "object",
            "additionalProperties": true,
            "required": ["provider", "auth", "model"],
            "properties": {
              "provider": {
                "type": "string",
                "minLength": 1
              },
              "auth": {
                "type": "string",
                "minLength": 1
              },
              "model": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "prompt_contract": {
            "type": "object",
            "additionalProperties": true,
            "anyOf": [
              {
                "required": ["path"]
              },
              {
                "required": ["schema"]
              },
              {
                "required": ["system_prompt", "user_template"]
              },
              {
                "required": ["system", "user"]
              }
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "schema": {
                "type": "string",
                "minLength": 1
              },
              "system_prompt": {
                "type": "string",
                "minLength": 1
              },
              "user_template": {
                "type": "string",
                "minLength": 1
              },
              "system": {
                "type": "string",
                "minLength": 1
              },
              "user": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": {
            "$ref": "#/$defs/dagIdentifier"
          },
          "to": {
            "$ref": "#/$defs/dagIdentifier"
          },
          "condition": {
            "$ref": "#/$defs/routeCondition"
          }
        }
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fail_closed_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
