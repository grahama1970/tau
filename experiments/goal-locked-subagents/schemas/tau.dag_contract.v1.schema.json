{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tau.dag_contract.v1",
  "title": "Tau Project-Agent DAG Contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "dag_id",
    "goal",
    "target",
    "entry_node",
    "terminal_nodes",
    "limits",
    "nodes",
    "edges",
    "required_evidence",
    "fail_closed_on"
  ],
  "properties": {
    "schema": {
      "const": "tau.dag_contract.v1"
    },
    "dag_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "provider_sensitive": {
      "type": "boolean"
    },
    "requires_provider_route": {
      "type": "boolean"
    },
    "goal": {
      "type": "object",
      "additionalProperties": true,
      "required": ["goal_id", "goal_version", "goal_hash"],
      "properties": {
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "goal_version": {
          "type": ["integer", "string"]
        },
        "goal_hash": {
          "type": "string",
          "pattern": "^sha256:.+"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repo", "target"],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "entry_node": {
      "type": "string",
      "minLength": 1
    },
    "terminal_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": true,
      "required": ["max_total_attempts"],
      "properties": {
        "resume": {
          "type": "boolean"
        },
        "default_timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_total_attempts": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "agent", "executor"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "executor": {
            "type": "string",
            "minLength": 1
          },
          "max_attempts": {
            "type": "integer",
            "minimum": 1
          },
          "command_spec": {
            "type": "string",
            "minLength": 1
          },
          "required_evidence": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reviewer": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "reviews_node": {
                "type": "string",
                "minLength": 1
              },
              "requires_goal_hash": {
                "type": "boolean"
              }
            }
          },
          "model_policy": {
            "type": "object",
            "additionalProperties": true,
            "required": ["provider", "auth", "model"],
            "properties": {
              "provider": {
                "type": "string",
                "minLength": 1
              },
              "auth": {
                "type": "string",
                "minLength": 1
              },
              "model": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "prompt_contract": {
            "type": "object",
            "additionalProperties": true,
            "anyOf": [
              {
                "required": ["path"]
              },
              {
                "required": ["schema"]
              },
              {
                "required": ["system_prompt", "user_template"]
              },
              {
                "required": ["system", "user"]
              }
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "schema": {
                "type": "string",
                "minLength": 1
              },
              "system_prompt": {
                "type": "string",
                "minLength": 1
              },
              "user_template": {
                "type": "string",
                "minLength": 1
              },
              "system": {
                "type": "string",
                "minLength": 1
              },
              "user": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["from", "to"],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "condition": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fail_closed_on": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
